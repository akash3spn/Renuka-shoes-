rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows any user to read the collections
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'mdsamirmolla87@gmail.com' || request.auth.token.email == 'parvejmolla100@gmail.com');
    }
    
    // Explicit rule for orders: users can write their own, admin can read/write all
    match /orders/{orderId} {
      allow create: if true; // Anyone can place an order
    }
  }
}
